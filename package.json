{
  "name": "suits",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live:case-compiler": "node --env-file-if-exists=.env.local --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run src/server/case-compiler/case-compiler.live.test.ts --reporter=verbose",
    "eval": "vitest run src/evals",
    "eval:gate3": "npx convex run autonomous:runGate3 '{\"runs\":5,\"promptVersion\":\"jury-review.v1\"}'"
  },
  "dependencies": {
    "convex": "^1.42.1",
    "mammoth": "1.12.0",
    "next": "16.2.10",
    "openai": "^6.46.0",
    "pdf-parse": "2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jszip": "3.10.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
