{
  "name": "suits",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:test:pdf": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-workerd-pdf.ps1",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "browser-install": "playwright install chromium",
    "test:live:case-compiler": "node --env-file-if-exists=.env.local --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run src/server/case-compiler/case-compiler.live.test.ts --reporter=verbose",
    "test:live:case-compiler-injection": "node --env-file-if-exists=.env.local --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run src/server/case-compiler/case-compiler.injection.live.test.ts --reporter=verbose",
    "test:live:courtroom-witness": "node --env-file-if-exists=.env.local --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run src/server/courtroom-ai/witness-runtime.live.test.ts --reporter=verbose",
    "eval": "vitest run src/evals",
    "eval:gate3": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-legacy-gate3.ps1",
    "verify:convex-surface": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-convex-public-surface.ps1",
    "verify": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify.ps1"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@react-three/fiber": "9.6.1",
    "convex": "^1.42.1",
    "next": "16.2.10",
    "openai": "^6.46.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "0.185.1",
    "unpdf": "1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "0.185.1",
    "@vitest/coverage-v8": "^4.1.10",
    "convex-test": "^0.0.54",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
