# Application model API (exact model ID must be verified)
OPENAI_API_KEY=
OPENAI_MODEL=
# Cost estimates are emitted only when this exact model and both rates are configured.
# gpt-5.4-mini is the model currently verified by this repository; set rates from your
# current OpenAI pricing source rather than copying an unsupported estimate.
OPENAI_PRICED_MODEL=gpt-5.4-mini
OPENAI_INPUT_USD_PER_MILLION_TOKENS=
OPENAI_OUTPUT_USD_PER_MILLION_TOKENS=

# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# ElevenLabs TTS/STT
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_VOICE_DIRECTOR=
ELEVENLABS_VOICE_ADVOCATE=
ELEVENLABS_VOICE_WITNESS=
ELEVENLABS_VOICE_JUROR_1=
ELEVENLABS_VOICE_JUROR_2=
ELEVENLABS_VOICE_JUROR_3=


# Optional partner integrations; never required for the golden path
LINKUP_API_KEY=
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
NEXT_PUBLIC_DODO_PAYMENTS_ENVIRONMENT=
