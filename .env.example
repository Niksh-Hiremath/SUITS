OPENAI_API_KEY=
OPENAI_LIVE_MODEL=gpt-5.6-luna
OPENAI_DEEP_MODEL=gpt-5.6-terra
RUN_OPENAI_LIVE=0
RUN_OPENAI_LIVE_INJECTION=0
RUN_OPENAI_LIVE_COURTROOM=0

# Written by `npx convex dev` when the local checkout is linked.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Use two different random values with at least 32 characters each.
# Configure SUITS_CONVEX_SERVICE_SECRET in both Next.js and the Convex deployment.
SUITS_CONVEX_SERVICE_SECRET=
SUITS_SESSION_SECRET=

# HTTPS canonical browser origin for every non-loopback deployment (for example,
# https://suits.example). Loopback development may leave this blank or use HTTP.
SUITS_PUBLIC_ORIGIN=

# Exact loopback WebSocket endpoint for the local speech companion. Raw
# microphone audio is sent only to this endpoint.
NEXT_PUBLIC_SUITS_SPEECH_URL=ws://127.0.0.1:8765/v1/speech

# Optional local-development fallback. Production builds ignore this flag and
# never render typed courtroom input.
NEXT_PUBLIC_SUITS_DEV_TYPED_INPUT=0

# Optional: vercel, cloudflare, x-real-ip, or x-forwarded-for. Leave blank unless
# the named reverse proxy overwrites that header before requests reach Next.js.
SUITS_TRUSTED_PROXY=
